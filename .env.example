# =============================================================================
# PULSEOS ENVIRONMENT VARIABLES — Production Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains sensitive credentials.

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4000
APP_BASE_URL=https://your-app.onrender.com

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# POOLER (port 6543) = app queries via PgBouncer — required for serverless
# DIRECT (port 5432) = migrations / prisma migrate deploy
# Password must be URL-encoded: @ → %40, # → %23, $ → %24, % → %25
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres?schema=public&sslmode=require

# -----------------------------------------------------------------------------
# Redis (Upstash — for BullMQ job queues, rate limiting, sessions)
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:YOUR_TOKEN@your-endpoint.upstash.io:6379

# -----------------------------------------------------------------------------
# Security — JWT & Encryption
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=your-64-char-hex-string-here
JWT_REFRESH_SECRET=your-64-char-hex-string-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=your-32-char-hex-string-here

# -----------------------------------------------------------------------------
# WhatsApp Business API (Meta)
# -----------------------------------------------------------------------------
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_ACCESS_TOKEN=your-permanent-access-token
WA_APP_SECRET=your-app-secret
WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# Deduplication TTL for webhook messages (seconds)
WA_WEBHOOK_MSG_DEDUPE_TTL_SEC=300

# -----------------------------------------------------------------------------
# Instagram / Facebook Graph API
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
INSTAGRAM_CLIENT_ID=your-client-id
INSTAGRAM_CLIENT_SECRET=your-client-secret
INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret
INSTAGRAM_REDIRECT_URI=https://your-app.onrender.com/api/auth/instagram/callback
INSTAGRAM_FRONTEND_REDIRECT_URI=https://your-dashboard.vercel.app/onboarding/callback
# Optional: comma-separated modes (webhook or poll)
INGESTION_MODE=webhook

# -----------------------------------------------------------------------------
# AI — OpenAI & Anthropic
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# -----------------------------------------------------------------------------
# Email (Postmark or SMTP)
# -----------------------------------------------------------------------------
POSTMARK_API_TOKEN=your-postmark-server-token
# Alternatively, use SMTP:
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourapp.com

# -----------------------------------------------------------------------------
# PDF Generation (Puppeteer)
# -----------------------------------------------------------------------------
# Local Chrome path (Windows example below — adjust for Linux/Mac)
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Optional: disable PDF generation entirely
# PDF_GENERATION=disabled

# -----------------------------------------------------------------------------
# Supabase (for RLS, auth, storage if needed)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Optional: custom secret for /api/metrics endpoint
METRICS_SECRET=your-metrics-secret

# -----------------------------------------------------------------------------
# Dashboard URLs
# -----------------------------------------------------------------------------
DASHBOARD_URL=https://your-dashboard.vercel.app
