# --- Runtime ---
NODE_ENV=development
PORT=4000
# Production API: https://social-media-controller.onrender.com
APP_BASE_URL=http://localhost:4000

# --- Database ---
# LOCAL: one Postgres URL for both (migrations + queries).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_controller?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/social_media_controller?schema=public
#
# SUPABASE + RENDER: split URLs are required in production.
# - DIRECT_URL = direct Postgres on :5432 for Prisma migrations / direct access
# - DATABASE_URL = transaction pooler on :6543 for runtime app usage
# Working project-specific examples:
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.lvlzugnoavgzwzulnnyf.supabase.co:5432/postgres?schema=public&sslmode=require
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.lvlzugnoavgzwzulnnyf.supabase.co:6543/postgres?schema=public&pgbouncer=true&sslmode=require
# Alternate pooler pattern: if Supabase shows aws-0-REGION.pooler.supabase.com, use the exact value Supabase provides.
# Do not guess or hand-edit the pooler hostname.

# --- Redis (optional for API boot — queues/cache skip if empty; use Upstash rediss:// or host Redis) ---
REDIS_URL=rediss://default:<PASSWORD>@<HOST>:<PORT>
# HTML→PDF: set either Gotenberg OR local Chrome for Puppeteer (Windows example):
# PUPPETEER_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# HTML→PDF via Gotenberg v8+ (optional). When set, PDF worker skips Puppeteer.
# GOTENBERG_URL=http://localhost:3000
# Disable PDF entirely (reports/export will 503 until re-enabled):
# PDF_GENERATION=disabled
#
# Briefing BullMQ: default hourly :00 IST. Set to nine_am_ist for whatsapp-briefing @ 09:00 only (see DEPLOYMENT.md).
# BRIEFING_DISPATCH_MODE=nine_am_ist
#
# PDF BullMQ: default embeds worker in API. Set false + run `npm run worker:pdf` on a separate worker dyno to isolate Puppeteer (OOM mitigation).
# START_PDF_WORKER_IN_API=false
# Email BullMQ: default embeds worker in API in production. Set false + run `npm run worker:email` on a separate worker dyno.
# Do not run both embedded + standalone email workers unless you intentionally want multiple consumers.
# START_EMAIL_WORKER_IN_API=false
# (WhatsApp outbound worker toggle — see WhatsApp Cloud API section below.)
# Recycle shared Chromium in the PDF worker after N jobs (limits RSS creep). Default 25.
# PDF_RECYCLE_AFTER_JOBS=25
# Enables GET /api/metrics (header x-pulse-metrics-key). Min 24 chars; omit if unused.
# METRICS_SECRET=

# --- Auth (secrets must be >= 32 chars; use openssl rand -base64 48) ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-32-chars-min
# Access token <= 15m required when NODE_ENV=production. Refresh <= 7d.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# When true: also set httpOnly JWT cookies (Bearer header still works). Use with credentialed CORS origins in production.
AUTH_HTTPONLY_COOKIES=true

# --- Encryption (32+ chars; social tokens at rest) ---
ENCRYPTION_KEY=replace-with-a-32-byte-secret-value-min-32

# --- Instagram / Meta (optional for demos — use INGESTION_MODE=mock) ---
# Meta often uses Facebook app id/secret for Instagram Login / Graph.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Unified Meta app (optional — falls back to FACEBOOK_APP_ID / INSTAGRAM_APP_ID)
META_APP_ID=
META_APP_SECRET=
# Base URL for OAuth redirect_uri (e.g. http://localhost:4000) — register /api/oauth/*/callback in each provider
OAUTH_REDIRECT_BASE_URL=http://localhost:4000
# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Server-side token exchange redirect (alias: /api/auth/instagram/callback). Must match Meta app settings if used.
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/auth/oauth/instagram/callback
# Browser OAuth return URL — must match Meta “Valid OAuth Redirect URIs” and match token exchange (Vercel app).
INSTAGRAM_FRONTEND_REDIRECT_URI=http://localhost:3000/onboarding/callback
# Production examples:
# OAUTH_REDIRECT_BASE_URL=https://social-media-controller.onrender.com
# INSTAGRAM_REDIRECT_URI=https://social-media-controller.onrender.com/api/auth/instagram/callback
# INSTAGRAM_FRONTEND_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback

# mock = demo-safe | instagram = real Graph path when tokens + app are configured
INGESTION_MODE=mock

# --- OpenAI (optional — insights/captions use deterministic fallbacks without key) ---
# Also used for Whisper voice-to-post transcription (/api/voice/transcribe).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic (for AI reply suggestions) ---
ANTHROPIC_API_KEY=your_key_here

# --- CORS (comma-separated origins). * allowed only when NODE_ENV is not production ---
# CORS_ORIGIN=https://social-media-controller.vercel.app,http://localhost:3000
CORS_ORIGIN=*

# Error tracking — get a free DSN from https://sentry.io
SENTRY_DSN=

# Shared secret for signed inbound social webhooks (send hex sha256 HMAC in X-Webhook-Signature or X-Hub-Signature-256).
WEBHOOK_SIGNING_SECRET=

# Meta Instagram DM webhook: GET verification token (hub.verify_token) and POST HMAC via META_APP_SECRET (or FACEBOOK_APP_SECRET / INSTAGRAM_APP_SECRET).
WEBHOOK_VERIFY_TOKEN=

# ── WhatsApp Cloud API (ingress + Graph outbound) — optional ─────────────────
# End-to-end: WA_PHONE_NUMBER_ID + token + WA_APP_SECRET + WEBHOOK_VERIFY_TOKEN + REDIS_URL + ingress/outbound workers.
WA_PHONE_NUMBER_ID=
# Meta permanent system-user token (Graph sends). WA_TOKEN is a legacy alias — same value as WA_ACCESS_TOKEN if set.
WA_ACCESS_TOKEN=
WA_TOKEN=
WA_APP_SECRET=
# Graph version segment only, e.g. v19.0 (no leading slash).
WA_API_VERSION=v19.0
# Optional: template name when freeform hits outside-window error 131047 (future automatic resend).
WA_FALLBACK_TEMPLATE_NAME=
# Optional: Redis SET NX TTL (seconds) on Meta message.id to drop duplicate webhook deliveries. 0 = off (default).
# WA_WEBHOOK_MSG_DEDUPE_TTL_SEC=0
#
# Worker control: embed Meta outbound BullMQ worker in API (default true). Set false and run `npm run worker:wa:outbound` on a worker dyno.
# START_WA_OUTBOUND_WORKER_IN_API=true

# --- Supabase (optional — WhatsApp session cold storage + media bucket) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_WHATSAPP_MEDIA_BUCKET=whatsapp-media
# true = log DMs only (no Graph send). false = real Graph API (requires approved instagram_manage_messages).
INSTAGRAM_MOCK_MODE=true
# Optional override for DM reply model (defaults to ANTHROPIC_BRIEFING_MODEL or Sonnet).
ANTHROPIC_DM_MODEL=

# --- Morning briefing (PulseOS) — optional ---
# Claude AI (optional) — get from https://console.anthropic.com
# Required for: AI-powered auto-replies in WhatsApp conversations, morning briefings, voice-to-post intent.
ANTHROPIC_API_KEY=
# Override default claude-sonnet-4-20250514 if needed
ANTHROPIC_BRIEFING_MODEL=
# Voice-to-post intent + caption (defaults to claude-3-5-sonnet-20241022 in code)
ANTHROPIC_VOICE_MODEL=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# --- Briefing live E2E / instrumentation (Cycle 5) ---
# Verbose logs: [briefing], [scheduler], [whatsapp] Twilio SID (use only during verification).
# DEBUG_BRIEFING=1
# Optional: override node-cron expression when Redis is off (default 0 * * * * = hourly :00 IST). Example test cadence: */2 * * * *
# BRIEFING_CRON_EXPRESSION=0 * * * *
# One-shot runBriefingNow after N ms (your controlled clientId + test WhatsApp on that client). Remove after successful run.
# BRIEFING_E2E_TEST_DELAY_MS=120000
# BRIEFING_E2E_TEST_CLIENT_ID=demo-client

# Email service (optional) — required for: transactional notifications, report delivery, some briefing paths.
# Prefer Postmark (default) or SES; SMTP is a fallback for WhatsApp-sender paths.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Optional "From" (defaults to SMTP_USER). Use your SendGrid verified sender if different.
SMTP_FROM=

# Email delivery (BullMQ + Postmark / SES)
# Queue-first only: API enqueues, worker sends.
EMAIL_FROM_ADDRESS=noreply@pulseos.in
EMAIL_FROM_NAME=PulseOS
# Optional reply-to shown in email clients
# EMAIL_REPLY_TO=hello@pulseos.in
# Provider selection: postmark (default) or ses
# EMAIL_PROVIDER=postmark
POSTMARK_API_TOKEN=
# Optional: require x-postmark-webhook-token on /api/webhooks/email/postmark
# POSTMARK_WEBHOOK_SECRET=
# Dev-only recipient override when NODE_ENV is not production
# EMAIL_DEV_INTERCEPT=dev@example.com
# Queue + retention tuning
# EMAIL_QUEUE_CONCURRENCY=5
# EMAIL_RATE_LIMIT_PER_HOUR=5
# EMAIL_RATE_LIMIT_PER_DAY=20
# EMAIL_DEDUPE_TTL_SECONDS=3600
# EMAIL_LOG_RETENTION_DAYS=90
# EMAIL_DLQ_ALERT_THRESHOLD=5
# DEFAULT_ALERT_EMAIL=admin@pulseos.in
# SES failover / primary (when EMAIL_PROVIDER=ses)
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=

# --- Stripe billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pioneer: INR 600/mo — create Product "PulseOS Pioneer Plan" + recurring monthly price in Stripe, paste price_… id
STRIPE_PRICE_PIONEER600_INR=
# Dashboard URL used for Stripe success/cancel/portal returns
DASHBOARD_URL=http://localhost:3000

# Dashboard: copy dashboard/.env.local.example to dashboard/.env.local and set:
# NEXT_PUBLIC_API_URL=http://localhost:4000 (local) or https://social-media-controller.onrender.com (production; no /api)
# NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000 (local) or https://social-media-controller.vercel.app (production)
# NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/onboarding/callback (local) or https://social-media-controller.vercel.app/onboarding/callback (production)
# NEXT_PUBLIC_ENABLE_MOCK_BILLING=true enables the local mocked billing flow when Razorpay keys are not set

# --- QuadraPilot (internal 4-agent pipeline helper; VS Code tasks / npm run quadra) ---
# Perplexity: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
QUADRAPILOT_OUTPUT_DIR=quadrapilot/output
QUADRAPILOT_PROJECT_NAME=PulseOS
QUADRAPILOT_STACK=Node.js/TypeScript/BullMQ/Prisma/Supabase
# Comma-separated basenames or paths — never inject into Antigravity prompt as editable targets
QUADRAPILOT_LOCKED_FILES=pdfQueueObservability.ts,pdfQueueMetricsFlush.ts
# Optional: Claude model for research questions (default claude-sonnet-4-20250514)
# QUADRAPILOT_CLAUDE_MODEL=
# Hint string embedded in Antigravity prompt (e.g. last green CI)
# QUADRAPILOT_CURRENT_TESTS=33/33
# Optional: editor CLI if not `code` on PATH
# QUADRAPILOT_CODE_CMD=code
