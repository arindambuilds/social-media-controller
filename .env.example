# --- Runtime ---
NODE_ENV=development
PORT=4000
# Production API: https://social-media-controller.onrender.com
APP_BASE_URL=http://localhost:4000

# --- Database ---
# LOCAL: one Postgres URL for both (migrations + queries).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_controller?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/social_media_controller?schema=public
#
# SUPABASE + RENDER: split URLs are required in production.
# - DIRECT_URL = direct Postgres on :5432 for Prisma migrations / direct access
# - DATABASE_URL = transaction pooler on :6543 for runtime app usage
# Working project-specific examples:
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.lvlzugnoavgzwzulnnyf.supabase.co:5432/postgres?schema=public&sslmode=require
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.lvlzugnoavgzwzulnnyf.supabase.co:6543/postgres?schema=public&pgbouncer=true&sslmode=require
# Alternate pooler pattern: if Supabase shows aws-0-REGION.pooler.supabase.com, use the exact value Supabase provides.
# Do not guess or hand-edit the pooler hostname.

# --- Redis (optional for API boot — queues/cache skip if empty; use Upstash rediss:// or host Redis) ---
REDIS_URL=rediss://default:<PASSWORD>@<HOST>:<PORT>

# --- Auth (secrets must be >= 32 chars; use openssl rand -base64 48) ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-32-chars-min
# Access token <= 15m required when NODE_ENV=production. Refresh <= 7d.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# When true: also set httpOnly JWT cookies (Bearer header still works). Use with credentialed CORS origins in production.
AUTH_HTTPONLY_COOKIES=false

# --- Encryption (32+ chars; social tokens at rest) ---
ENCRYPTION_KEY=replace-with-a-32-byte-secret-value-min-32

# --- Instagram / Meta (optional for demos — use INGESTION_MODE=mock) ---
# Meta often uses Facebook app id/secret for Instagram Login / Graph.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Unified Meta app (optional — falls back to FACEBOOK_APP_ID / INSTAGRAM_APP_ID)
META_APP_ID=
META_APP_SECRET=
# Base URL for OAuth redirect_uri (e.g. http://localhost:4000) — register /api/oauth/*/callback in each provider
OAUTH_REDIRECT_BASE_URL=http://localhost:4000
# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Server-side token exchange redirect (alias: /api/auth/instagram/callback). Must match Meta app settings if used.
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/auth/oauth/instagram/callback
# Browser OAuth return URL — must match Meta “Valid OAuth Redirect URIs” and match token exchange (Vercel app).
INSTAGRAM_FRONTEND_REDIRECT_URI=http://localhost:3000/onboarding/callback
# Production examples:
# OAUTH_REDIRECT_BASE_URL=https://social-media-controller.onrender.com
# INSTAGRAM_REDIRECT_URI=https://social-media-controller.onrender.com/api/auth/instagram/callback
# INSTAGRAM_FRONTEND_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback

# mock = demo-safe | instagram = real Graph path when tokens + app are configured
INGESTION_MODE=mock

# --- OpenAI (optional — insights/captions use deterministic fallbacks without key) ---
# Also used for Whisper voice-to-post transcription (/api/voice/transcribe).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- CORS (comma-separated origins). * allowed only when NODE_ENV is not production ---
# CORS_ORIGIN=https://social-media-controller.vercel.app,http://localhost:3000
CORS_ORIGIN=*

# Error tracking — get a free DSN from https://sentry.io
SENTRY_DSN=

# Shared secret for signed inbound social webhooks (send hex sha256 HMAC in X-Webhook-Signature or X-Hub-Signature-256).
WEBHOOK_SIGNING_SECRET=

# Meta Instagram DM webhook: GET verification token (hub.verify_token) and POST HMAC via META_APP_SECRET (or FACEBOOK_APP_SECRET / INSTAGRAM_APP_SECRET).
WEBHOOK_VERIFY_TOKEN=
# true = log DMs only (no Graph send). false = real Graph API (requires approved instagram_manage_messages).
INSTAGRAM_MOCK_MODE=true
# Optional override for DM reply model (defaults to ANTHROPIC_BRIEFING_MODEL or Sonnet).
ANTHROPIC_DM_MODEL=

# --- Morning briefing (PulseOS) — optional ---
# Anthropic
ANTHROPIC_API_KEY=
# Override default claude-sonnet-4-20250514 if needed
ANTHROPIC_BRIEFING_MODEL=
# Voice-to-post intent + caption (defaults to claude-3-5-sonnet-20241022 in code)
ANTHROPIC_VOICE_MODEL=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Email (SMTP fallback)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Dashboard: copy dashboard/.env.local.example to dashboard/.env.local and set:
# NEXT_PUBLIC_API_URL=http://localhost:4000 (local) or https://your-api.onrender.com (production; no /api)
# NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback
