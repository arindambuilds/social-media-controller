# PulseOS / social-media-controller environment template
# Copy this file to `.env` for local work, or mirror the same keys in Render/Vercel.
# Never commit real credentials.

# Runtime mode and public URLs
# NODE_ENV: `development` locally, `production` on Render.
NODE_ENV=development
# PORT: local API port.
PORT=4000
# APP_BASE_URL: your Render API base URL.
APP_BASE_URL=https://your-api.onrender.com
# DASHBOARD_URL: your Vercel dashboard URL used for redirects and CORS.
DASHBOARD_URL=https://your-dashboard.vercel.app
# CORS_ORIGIN: comma-separated list of allowed frontend origins.
CORS_ORIGIN=https://your-dashboard.vercel.app

# Postgres / Supabase
# DATABASE_URL: pooled Supabase/Neon/Render runtime URL. Use the PgBouncer/pooler host on port 6543.
DATABASE_URL=postgresql://postgres:YOUR_URLENCODED_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL: direct Postgres connection for Prisma migrate/introspection. Use the direct host on port 5432.
DIRECT_URL=postgresql://postgres:YOUR_URLENCODED_PASSWORD@db.your-project.supabase.co:5432/postgres?schema=public&sslmode=require

# Redis / Upstash
# REDIS_URL: Upstash Redis connection string used by BullMQ and rate limiting.
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@your-upstash-endpoint.upstash.io:6379

# Auth and encryption
# JWT_SECRET: generate with `openssl rand -hex 32`.
JWT_SECRET=replace-with-a-64-char-hex-secret
# JWT_REFRESH_SECRET: generate with `openssl rand -hex 32`.
JWT_REFRESH_SECRET=replace-with-a-second-64-char-hex-secret
# JWT_EXPIRES_IN: access token lifetime.
JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN: refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d
# ENCRYPTION_KEY: generate with `openssl rand -hex 16`.
ENCRYPTION_KEY=replace-with-a-32-char-hex-key
# ENCRYPTION_KEY_PREV: previous encryption key used during rotation, if any.
ENCRYPTION_KEY_PREV=

# OpenAI / Anthropic
# OPENAI_API_KEY: create in the OpenAI dashboard.
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL: optional default model for OpenAI features.
OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY: create in the Anthropic console.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_BRIEFING_MODEL: optional model override for briefing generation.
ANTHROPIC_BRIEFING_MODEL=
# ANTHROPIC_VOICE_MODEL: optional model override for voice flows.
ANTHROPIC_VOICE_MODEL=

# WhatsApp Business API / Meta
# WA_PHONE_NUMBER_ID: Meta App Dashboard > WhatsApp > API Setup.
WA_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
# WA_ACCESS_TOKEN: permanent WhatsApp Cloud API token from Meta.
WA_ACCESS_TOKEN=your-whatsapp-cloud-token
# WHATSAPP_ACCESS_TOKEN: compatibility alias for the same Meta token. Keep it identical to WA_ACCESS_TOKEN.
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-token
# WA_APP_SECRET: Meta App Dashboard > App settings > Basic.
WA_APP_SECRET=your-meta-app-secret
# WEBHOOK_VERIFY_TOKEN: random string you choose for Meta webhook verification.
WEBHOOK_VERIFY_TOKEN=replace-with-a-random-webhook-token
# WA_WEBHOOK_MSG_DEDUPE_TTL_SEC: Redis dedupe window for duplicate webhook deliveries.
WA_WEBHOOK_MSG_DEDUPE_TTL_SEC=300

# Instagram / Facebook OAuth
# FACEBOOK_APP_ID: Meta App Dashboard > App settings > Basic.
FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET: Meta App Dashboard > App settings > Basic.
FACEBOOK_APP_SECRET=your-facebook-app-secret
# INSTAGRAM_APP_ID: Meta App Dashboard app ID used for Instagram login/OAuth.
INSTAGRAM_APP_ID=your-instagram-app-id
# INSTAGRAM_APP_SECRET: Meta App Dashboard app secret used for Instagram login/OAuth.
INSTAGRAM_APP_SECRET=your-instagram-app-secret
# INSTAGRAM_CLIENT_ID: optional alias used by some older OAuth flows.
INSTAGRAM_CLIENT_ID=your-instagram-client-id
# INSTAGRAM_CLIENT_SECRET: optional alias used by some older OAuth flows.
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
# INSTAGRAM_REDIRECT_URI: API callback URL configured in the Meta app.
INSTAGRAM_REDIRECT_URI=https://your-api.onrender.com/api/auth/oauth/instagram/callback
# INSTAGRAM_FRONTEND_REDIRECT_URI: dashboard callback page after OAuth.
INSTAGRAM_FRONTEND_REDIRECT_URI=https://your-dashboard.vercel.app/onboarding/callback
# INGESTION_MODE: `instagram` for live ingestion, `mock` for demo mode.
INGESTION_MODE=instagram

# Supabase service access
# SUPABASE_URL: Supabase project URL from Project Settings > API.
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: Supabase Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Billing and payments
# STRIPE_SECRET_KEY: Stripe Developers > API keys.
STRIPE_SECRET_KEY=sk_live_or_test_key
# STRIPE_WEBHOOK_SECRET: Stripe Developers > Webhooks signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRICE_PIONEER600_INR: recurring price ID for the Pioneer plan.
STRIPE_PRICE_PIONEER600_INR=price_your_price_id

# Email delivery
# EMAIL_PROVIDER: `postmark` or `ses`.
EMAIL_PROVIDER=postmark
# POSTMARK_API_TOKEN: Postmark server token.
POSTMARK_API_TOKEN=your-postmark-token
# EMAIL_FROM_ADDRESS: verified sender address used by Postmark/SES.
EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME: sender display name.
EMAIL_FROM_NAME=PulseOS
# EMAIL_REPLY_TO: optional reply-to address.
EMAIL_REPLY_TO=
# DEFAULT_ALERT_EMAIL: mailbox for operational alerts.
DEFAULT_ALERT_EMAIL=alerts@example.com

# Optional SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Monitoring and misc
# SENTRY_DSN: Sentry project DSN for backend error reporting.
SENTRY_DSN=
# METRICS_SECRET: 24+ char secret for the protected metrics endpoint.
METRICS_SECRET=
# AUTH_HTTPONLY_COOKIES: set to `true` for dashboard/browser auth.
AUTH_HTTPONLY_COOKIES=true
# START_WA_OUTBOUND_WORKER_IN_API: keep `true` unless you run a dedicated outbound worker.
START_WA_OUTBOUND_WORKER_IN_API=true
# START_PDF_WORKER_IN_API: keep `true` unless you run a dedicated PDF worker service.
START_PDF_WORKER_IN_API=true
# START_EMAIL_WORKER_IN_API: keep `true` unless you run a dedicated email worker service.
START_EMAIL_WORKER_IN_API=true
