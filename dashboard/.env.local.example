# Copy to dashboard/.env.local for local customer-view testing.
# Origin only — code appends /api for JSON routes.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Local dashboard origin and OAuth callback.
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=http://localhost:3000/onboarding/callback

# Local customer flow uses a clearly labeled mock checkout by default.
NEXT_PUBLIC_ENABLE_MOCK_BILLING=true

# Leave blank when using the local mock checkout.
# Fill these with real Razorpay test keys only if you want a real sandbox modal locally.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Production (Vercel / hosted dashboard): use your Render API origin only — no /api suffix.
# NEXT_PUBLIC_API_URL=https://social-media-controller.onrender.com
