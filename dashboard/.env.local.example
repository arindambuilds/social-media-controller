# Copy to dashboard/.env.local — origin only (code appends /api).
# Required for NotificationBell and all API calls; without it the dashboard throws in production builds.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Production (Vercel / hosted dashboard): use your Render API origin only — no /api suffix.
# NEXT_PUBLIC_API_URL=https://social-media-controller.onrender.com
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback
