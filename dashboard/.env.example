# Copy to .env.local — API origin only (lib/api.ts adds /api)
# Optional: same Upstash/Redis URL as API — enables pulse:analytics:events stream + funnel merge (skips localhost)
REDIS_URL=

NEXT_PUBLIC_API_URL=https://social-media-controller.onrender.com
# Optional: onboarding return URL (must match Meta + INSTAGRAM_FRONTEND_REDIRECT_URI on API)
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=
# Same Stripe Price id as API STRIPE_PRICE_PIONEER600_INR (INR 600/mo Pioneer) — optional if only server env set
NEXT_PUBLIC_STRIPE_PIONEER600_PRICE_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_DASHBOARD_URL=https://social-media-controller.vercel.app
