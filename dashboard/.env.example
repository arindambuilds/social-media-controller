# Copy to dashboard/.env.local for local work, or set these in Vercel for production.
# API origin only — dashboard/lib/api.ts appends /api for JSON routes.
# Optional: same Upstash/Redis URL as API — enables pulse:analytics:events stream + funnel merge (skips localhost)
REDIS_URL=

NEXT_PUBLIC_API_BASE_URL=https://social-media-controller.onrender.com
NEXT_PUBLIC_API_URL=https://social-media-controller.onrender.com
NEXT_PUBLIC_DASHBOARD_URL=https://social-media-controller.vercel.app
# Must match INSTAGRAM_FRONTEND_REDIRECT_URI on the backend.
NEXT_PUBLIC_INSTAGRAM_REDIRECT_URI=https://social-media-controller.vercel.app/onboarding/callback

# Local mock billing stays off in cloud. Set true only for local customer-flow demos without Razorpay keys.
NEXT_PUBLIC_ENABLE_MOCK_BILLING=false

# Razorpay checkout for cloud/test mode. Leave empty until you have real test or live keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
